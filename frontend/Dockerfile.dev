# Frontend Development Dockerfile
# Uses Vite's built-in HMR

FROM node:20-alpine

WORKDIR /app

# Copy package files first for better caching
COPY package*.json ./
RUN npm install

# Copy the rest of the source code
COPY . ./

# Expose Vite dev server port
EXPOSE 5173

# Copy docker-specific vite config
COPY vite.config.docker.js ./vite.config.docker.js

# Run Vite dev server with docker config
CMD ["npx", "vite", "--config", "vite.config.docker.js"]
