[Unit]
Description=Pi GPIO Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/pi-gpio-dashboard
Restart=always
RestartSec=5
Environment="CONFIG_PATH=/etc/pi-gpio/config.toml"
Environment="MOCK_GPIO=false"

[Install]
WantedBy=multi-user.target